includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
        - database
    tmpDir: build/phpstan
    stubFiles:
        - stubs/horizon.stub
    ignoreErrors:
        -
            message: '#Parameter \#1 \$view of function view expects view-string\|null, string given\.#'
            path: src/*
